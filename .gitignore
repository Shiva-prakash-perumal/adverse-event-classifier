# ─── Environment variables (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
.pem


# ─── Data files (often too large for git) ────────────────────────────────────
data/
data/*.csv
data/*.parquet
data/*.json
data/*.zip
data/*.txt

# ─── Model artifacts ──────────────────────────────────────────────────────────
models/
models_initial/
models_classImbalance/
models_hyperparametertuning/

