# ─── Mistral Gateway (3DS Proxem) ─────────────────────────────────────────────
# Get your API key from the 3DS Proxem gateway portal
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=your_mistral_url
MISTRAL_MODEL=your_model_name
MISTRAL_CERT_PATH=path/to/your/certificate.pem

# ─── OpenAI (optional fallback) ───────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
EXPERIMENT_NAME=adverse_event_classifier
